<DashboardTile>:
    size_hint_x: 1
    size_hint_y: None
    height: dp(105)
    radius: [18]
    ripple_behavior: True
    elevation: 1

    MDBoxLayout:
        orientation: "horizontal"
        padding: dp(18), dp(12)
        spacing: dp(12)

        MDBoxLayout:
            orientation: "vertical"
            spacing: dp(4)

            MDLabel:
                id: tile_label
                text: root.label
                halign: "left"
                theme_text_color: "Custom"
                font_style: "Title"
                role: "medium"
                adaptive_height: True

            MDLabel:
                id: tile_subtitle
                text: root.subtitle
                halign: "left"
                theme_text_color: "Custom"
                font_style: "Body"
                role: "small"
                adaptive_height: True

        MDIconButton:
            id: tile_icon
            icon: root.icon_name
            theme_icon_color: "Custom"
            size_hint: None, None
            size: dp(54), dp(54)
            pos_hint: {"center_y": 0.5}
            on_release: root.on_release()

<HomeScreen>:
    MDBoxLayout:
        id: drawer_layout
        orientation: "vertical"

        MDBoxLayout:
            size_hint_y: None
            height: dp(56)
            padding: dp(8)

            MDIconButton:
                id: menu_button
                icon: "cog-outline"
                theme_icon_color: "Custom"
                on_release: root.open_settings()

            MDLabel:
                id: drawer_title
                text: "NoteNest"
                theme_text_color: "Custom"
                font_style: "Title"
                role: "medium"

        AnchorLayout:
            anchor_x: "center"
            anchor_y: "top"
            padding: dp(24), dp(35), dp(24), dp(24)

            MDBoxLayout:
                orientation: "vertical"
                spacing: dp(14)
                size_hint: None, None
                width: root.width - dp(48) if root.width < dp(500) else dp(430)
                height: self.minimum_height

                MDLabel:
                    id: home_label
                    text: "Let's get you started for the day"
                    halign: "center"
                    theme_text_color: "Custom"
                    font_style: "Title"
                    role: "large"
                    size_hint_y: None
                    height: dp(48)

                MDLabel:
                    id: home_subtitle
                    text: "Pick a space to write, focus, or plan your tasks."
                    halign: "center"
                    theme_text_color: "Custom"
                    font_style: "Body"
                    role: "medium"
                    size_hint_y: None
                    height: dp(42)

                MDBoxLayout:
                    id: tiles_row
                    orientation: "vertical"
                    spacing: dp(14)
                    adaptive_height: True

                    DashboardTile:
                        label: "Notes"
                        subtitle: "Write and organize your ideas"
                        icon_name: "notebook-outline"
                        target_screen: "notes"

                    DashboardTile:
                        label: "Pomodoro"
                        subtitle: "Focus with timed study sessions"
                        icon_name: "timer-sand"
                        target_screen: "timer"

                    DashboardTile:
                        label: "Tasks & Calendar"
                        subtitle: "Track deadlines, priorities, and reminders"
                        icon_name: "calendar-check-outline"
                        target_screen: "calendar"

# ── NoteCard ──────────────────────────────────────────────────
<NoteCard>:
    orientation: "vertical"
    padding: "16dp"
    spacing: "6dp"
    size_hint_y: None
    height: "100dp"
    radius: [16, 16, 16, 16]
    ripple_behavior: True
    elevation: 2
    md_bg_color: 0.97, 0.95, 0.90, 1

    MDBoxLayout:
        orientation: "horizontal"
        adaptive_height: True
        spacing: "6dp"

        MDLabel:
            text: root.title
            font_style: "Title"
            role: "medium"
            adaptive_height: True
            shorten: True
            shorten_from: "right"
            theme_text_color: "Custom"
            text_color: 0.29, 0.20, 0.15, 1

        MDIconButton:
            id: pin_icon
            # filled pin if pinned, outline if not -- updates
            # automatically whenever root.is_pinned changes
            icon: "pin" if root.is_pinned else "pin-outline"
            theme_icon_color: "Custom"
            icon_color: 0.54, 0.35, 0.17, 1
            size_hint: None, None
            size: dp(36), dp(36)
            on_release: root.toggle_pin()

    MDLabel:
        text: root.preview
        font_style: "Body"
        role: "small"
        adaptive_height: True
        shorten: True
        shorten_from: "right"
        theme_text_color: "Custom"
        text_color: 0.54, 0.35, 0.17, 1
        
# ── AttachmentThumbnail ──────────────────────────────────────────
<AttachmentThumbnail>:
    size_hint: None, None
    size: dp(72), dp(72)
    radius: [8]
    md_bg_color: 0.92, 0.84, 0.66, 1

    Image:
        source: root.image_path
        size_hint: 1, 1
        pos_hint: {"x": 0, "y": 0}
        allow_stretch: True
        keep_ratio: False

    MDIconButton:
        icon: "close-circle"
        pos_hint: {"right": 1, "top": 1}
        size_hint: None, None
        size: dp(20), dp(20)
        theme_icon_color: "Custom"
        icon_color: 1, 1, 1, 1
        on_release: root.request_remove()

# ── NotesScreen ────────────────────────────────────────────────
<NotesScreen>:
    id: notes_screen_root

    FloatLayout:

        MDBoxLayout:
            orientation: "vertical"
            size_hint: 1, 1

            MDFloatLayout:
                id: top_bar
                size_hint_y: None
                height: "56dp"

                MDIconButton:
                    id: back_button
                    icon: "arrow-left"
                    theme_icon_color: "Custom"
                    pos_hint: {"x": 0, "center_y": 0.5}
                    on_release: root.go_home()

                MDLabel:
                    id: header_label
                    text: "Notes"
                    font_style: "Title"
                    role: "large"
                    theme_text_color: "Custom"
                    halign: "center"
                    valign: "middle"
                    text_size: self.size
                    size_hint: 1, 1
                    pos_hint: {"x": 0, "y": 0}

                MDBoxLayout:
                    size_hint: None, None
                    size: "88dp", "48dp"
                    spacing: "4dp"
                    pos_hint: {"right": 1, "center_y": 0.5}

                    MDIconButton:
                        id: sort_title_button
                        icon: "sort-alphabetical-ascending"
                        theme_icon_color: "Custom"
                        on_release: root.sort_notes('title')

                    MDIconButton:
                        id: sort_date_button
                        icon: "sort-calendar-ascending"
                        theme_icon_color: "Custom"
                        on_release: root.sort_notes('date')

            MDBoxLayout:
                id: search_bar
                size_hint_y: None
                height: "72dp"
                padding: "16dp", "8dp"

                MDTextField:
                    id: search_field
                    on_text: root.search_notes(self.text)

                    MDTextFieldHintText:
                        text: "Search notes..."

            ScrollView:
                size_hint: 1, 1

                MDBoxLayout:
                    id: notes_list
                    orientation: "vertical"
                    padding: "12dp"
                    spacing: "10dp"
                    adaptive_height: True

        MDFabButton:
            id: add_note_fab
            icon: "plus"
            pos_hint: {"right": 0.93, "y": 0.04}
            theme_icon_color: "Custom"
            on_release: root.open_note_editor()

<NoteEditorScreen>:
    name: "note_editor"

    MDBoxLayout:
        id: screen_container
        orientation: "vertical"
        size_hint: 1, 1

        MDBoxLayout:
            id: top_bar
            size_hint_y: None
            height: "56dp"
            padding: "4dp"
            spacing: "4dp"

            MDIconButton:
                id: back_button
                icon: "arrow-left"
                theme_icon_color: "Custom"
                on_release: app.root.get_screen('note_editor').go_back()

            MDLabel:
                id: header_label
                text: "My Note"
                font_style: "Title"
                role: "large"
                theme_text_color: "Custom"
                size_hint_x: 1

            MDIconButton:
                id: image_button
                icon: "image-plus"
                theme_icon_color: "Custom"
                on_release: app.root.get_screen('note_editor').pick_image()

            MDIconButton:
                id: preview_button
                icon: "eye-outline"
                theme_icon_color: "Custom"
                on_release: app.root.get_screen('note_editor').toggle_preview()

            MDIconButton:
                id: duplicate_button
                icon: "content-copy"
                theme_icon_color: "Custom"
                on_release: app.root.get_screen('note_editor').duplicate_note()

            MDIconButton:
                id: delete_button
                icon: "delete"
                theme_icon_color: "Custom"
                on_release: app.root.get_screen('note_editor').delete_note()

            MDIconButton:
                id: save_button
                icon: "content-save"
                theme_icon_color: "Custom"
                on_release: app.root.get_screen('note_editor').save_note()

        MDBoxLayout:
            id: title_field_container
            size_hint_y: None
            height: "72dp"
            padding: "16dp", "8dp"

            MDTextField:
                id: title_field

                MDTextFieldHintText:
                    text: "Title"

        # ── formatting toolbar: bold, italic, underline, highlight,
        #    font size, font family ──
        MDBoxLayout:
            id: toolbar
            size_hint_y: None
            height: "48dp"
            padding: "8dp", "4dp"
            spacing: "4dp"

            MDIconButton:
                id: bold_button
                icon: "format-bold"
                theme_icon_color: "Custom"
                on_release: app.root.get_screen('note_editor').make_bold()

            MDIconButton:
                id: italic_button
                icon: "format-italic"
                theme_icon_color: "Custom"
                on_release: app.root.get_screen('note_editor').make_italic()

            MDIconButton:
                id: underline_button
                icon: "format-underline"
                theme_icon_color: "Custom"
                on_release: app.root.get_screen('note_editor').make_underline()

            MDIconButton:
                id: highlight_button
                icon: "marker"
                theme_icon_color: "Custom"
                on_release: app.root.get_screen('note_editor').make_highlight()

            MDIconButton:
                id: align_left_button
                icon: "format-align-left"
                theme_icon_color: "Custom"
                on_release: app.root.get_screen('note_editor').set_align_left()

            MDIconButton:
                id: align_center_button
                icon: "format-align-center"
                theme_icon_color: "Custom"
                on_release: app.root.get_screen('note_editor').set_align_center()

            MDIconButton:
                id: align_right_button
                icon: "format-align-right"
                theme_icon_color: "Custom"
                on_release: app.root.get_screen('note_editor').set_align_right()

            Widget:
                # empty spacer -- pushes the font controls to the right

            MDIconButton:
                id: font_decrease_button
                icon: "format-font-size-decrease"
                theme_icon_color: "Custom"
                on_release: app.root.get_screen('note_editor').decrease_font_size()

            MDIconButton:
                id: font_increase_button
                icon: "format-font-size-increase"
                theme_icon_color: "Custom"
                on_release: app.root.get_screen('note_editor').increase_font_size()

            MDIconButton:
                id: font_cycle_button
                icon: "format-font"
                theme_icon_color: "Custom"
                on_release: app.root.get_screen('note_editor').cycle_font()

        MDCard:
            id: content_card
            orientation: "vertical"
            size_hint: 1, 1
            padding: "20dp"
            radius: [20, 20, 20, 20]
            elevation: 1

            MDBoxLayout:
                id: content_container
                orientation: "vertical"
                size_hint: 1, 1

                TextInput:
                    id: content_field
                    multiline: True
                    size_hint: 1, 1
                    font_size: "16sp"
                    hint_text: "Start writing..."
                    # Clearing these removes Kivy's default TextInput border/atlas image,
                    # so background_color actually shows instead of being overridden.
                    background_normal: ""
                    background_active: ""
                    padding: dp(8), dp(8), dp(8), dp(8)
                                        