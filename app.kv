# ── NoteCard ──────────────────────────────────────────────────
<NoteCard>:
    orientation: "vertical"
    padding: "16dp"
    spacing: "6dp"
    size_hint_y: None
    height: "100dp"
    radius: [16, 16, 16, 16]
    ripple_behavior: True
    elevation: 2
    md_bg_color: 0.97, 0.95, 0.90, 1

    MDLabel:
        text: root.title
        font_style: "Title"
        role: "medium"
        adaptive_height: True
        shorten: True
        shorten_from: "right"
        theme_text_color: "Custom"
        text_color: 0.29, 0.20, 0.15, 1

    MDLabel:
        text: root.preview
        font_style: "Body"
        role: "small"
        adaptive_height: True
        shorten: True
        shorten_from: "right"
        theme_text_color: "Custom"
        text_color: 0.54, 0.35, 0.17, 1


# ── HomeScreen ────────────────────────────────────────────────
<HomeScreen>:
    name: "home"
    md_bg_color: 0.97, 0.95, 0.90, 1

    FloatLayout:

        MDBoxLayout:
            orientation: "vertical"
            size_hint: 1, 1
            md_bg_color: 0.97, 0.95, 0.90, 1

            # custom toolbar
            MDBoxLayout:
                size_hint_y: None
                height: "56dp"
                padding: "8dp", "4dp"
                spacing: "4dp"
                md_bg_color: 0.92, 0.84, 0.66, 1

                MDLabel:
                    text: "NoteNest"
                    font_style: "Title"
                    role: "large"
                    theme_text_color: "Custom"
                    text_color: 0.29, 0.20, 0.15, 1
                    size_hint_x: 1

                MDIconButton:
                    icon: "sort-alphabetical-ascending"
                    theme_icon_color: "Custom"
                    icon_color: 0.29, 0.20, 0.15, 1
                    on_release: app.root.get_screen('home').sort_notes('title')

                MDIconButton:
                    icon: "sort-calendar-ascending"
                    theme_icon_color: "Custom"
                    icon_color: 0.29, 0.20, 0.15, 1
                    on_release: app.root.get_screen('home').sort_notes('date')

            MDBoxLayout:
                size_hint_y: None
                height: "72dp"
                padding: "16dp", "8dp"
                md_bg_color: 0.97, 0.95, 0.90, 1

                MDTextField:
                    id: search_field
                    on_text: app.root.get_screen('home').search_notes(self.text)

                    MDTextFieldHintText:
                        text: "Search notes..."

            ScrollView:
                size_hint: 1, 1

                MDBoxLayout:
                    id: notes_list
                    orientation: "vertical"
                    padding: "12dp"
                    spacing: "10dp"
                    adaptive_height: True
                    md_bg_color: 0.97, 0.95, 0.90, 1

        MDFabButton:
            icon: "plus"
            pos_hint: {"right": 0.93, "y": 0.04}
            md_bg_color: 0.72, 0.79, 0.54, 1
            theme_icon_color: "Custom"
            icon_color: 0.29, 0.20, 0.15, 1
            on_release: app.root.get_screen('home').open_note_editor()


# ── NoteEditorScreen ──────────────────────────────────────────
<NoteEditorScreen>:
    name: "note_editor"
    md_bg_color: 0.97, 0.95, 0.90, 1

    MDBoxLayout:
        orientation: "vertical"
        size_hint: 1, 1
        md_bg_color: 0.97, 0.95, 0.90, 1

        # custom toolbar with explicit icon colors
        MDBoxLayout:
            size_hint_y: None
            height: "56dp"
            padding: "4dp"
            spacing: "4dp"
            md_bg_color: 0.92, 0.84, 0.66, 1

            MDIconButton:
                icon: "arrow-left"
                theme_icon_color: "Custom"
                icon_color: 0.29, 0.20, 0.15, 1
                on_release: app.root.get_screen('note_editor').go_back()

            MDLabel:
                text: "My Note"
                font_style: "Title"
                role: "large"
                theme_text_color: "Custom"
                text_color: 0.29, 0.20, 0.15, 1
                size_hint_x: 1

            MDIconButton:
                icon: "content-copy"
                theme_icon_color: "Custom"
                icon_color: 0.29, 0.20, 0.15, 1
                on_release: app.root.get_screen('note_editor').duplicate_note()

            MDIconButton:
                icon: "delete"
                theme_icon_color: "Custom"
                icon_color: 0.29, 0.20, 0.15, 1
                on_release: app.root.get_screen('note_editor').delete_note()

            MDIconButton:
                icon: "content-save"
                theme_icon_color: "Custom"
                icon_color: 0.29, 0.20, 0.15, 1
                on_release: app.root.get_screen('note_editor').save_note()

        MDBoxLayout:
            size_hint_y: None
            height: "72dp"
            padding: "16dp", "8dp"
            md_bg_color: 0.97, 0.95, 0.90, 1

            MDTextField:
                id: title_field

                MDTextFieldHintText:
                    text: "Title"

        ScrollView:
            size_hint: 1, 1

            MDBoxLayout:
                padding: "16dp", "8dp"
                size_hint_y: None
                height: self.minimum_height
                md_bg_color: 0.97, 0.95, 0.90, 1

                MDTextField:
                    id: content_field
                    multiline: True
                    size_hint_y: None
                    height: max(self.minimum_height, dp(400))

                    MDTextFieldHintText:
                        text: "Start writing..."

#timerui
<TimerScreen>:
    md_bg_color: "#F7F1E6"

    MDBoxLayout:
        orientation: "vertical"
        spacing: "25dp"
        padding: "25dp"

        Widget:
            size_hint_y: .15

        MDLabel:
            text: "Pomodoro Timer"
            halign: "center"
            font_style: "Headline"

        MDLabel:
            id: session_label
            text: "Focus Time"
            halign: "center"
            font_style: "Title"

        MDLabel:
            id: timer_label
            text: "25:00"
            halign: "center"
            font_style: "Display"

        Widget:

        MDBoxLayout:
            adaptive_height: True
            spacing: "15dp"
            size_hint_x: None
            width: self.minimum_width
            pos_hint: {"center_x": .5}

            MDButton:
                style: "filled"
                on_release: root.start_timer()
                MDButtonText:
                    text: "Start"

            MDButton:
                style: "filled"
                on_release: root.pause_timer()
                MDButtonText:
                    text: "Pause"

            MDButton:
                style: "filled"
                on_release: root.reset_timer()
                MDButtonText:
                    text: "Reset"

            MDButton:
                style: "filled"
                on_release:
                    root.open_timer_dialog()
                MDButtonText:
                    text: "Set Timer"

        Widget:
            size_hint_y: .2

<SettingsScreen>:
    md_bg_color: "#F4ECDC"

    MDBoxLayout:
        orientation: "vertical"
        padding: "20dp"
        spacing: "18dp"

        MDBoxLayout:
            adaptive_height: True
            spacing: "12dp"
            padding: "0dp", "8dp"

            MDButton:
                style: "text"
                on_release: root.go_back()

                MDButtonIcon:
                    icon: "arrow-left"

            MDLabel:
                id: title_label
                text: "Settings"
                font_style: "Headline"
                theme_text_color: "Custom"
                text_color: "#050302"

        MDLabel:
            id: subtitle_label
            text: "Customize your NoteNest experience"
            adaptive_height: True
            font_style: "Body"
            theme_text_color: "Custom"
            text_color: "#6D6861"

        ScrollView:

            MDBoxLayout:
                orientation: "vertical"
                adaptive_height: True
                spacing: "22dp"
                padding: "4dp", "20dp", "4dp", "20dp"

                MDCard:
                    id: appearance_card
                    style: "filled"
                    md_bg_color: "#E7E1D4"
                    size_hint_y: None
                    height: "190dp"

                    MDBoxLayout:
                        orientation: "vertical"
                        padding: "18dp"
                        spacing: "10dp"

                        MDLabel:
                            text: "Theme"
                            font_style: "Title"
                            theme_text_color: "Custom"
                            text_color: "#4A3426"

                        MDLabel:
                            text: "Choose your preferred appearance"
                            adaptive_height: True
                            theme_text_color: "Custom"
                            text_color: "#8A5A2B"

                        ScrollView:
                            do_scroll_x: True
                            do_scroll_y: False
                            bar_width: "4dp"

                            MDBoxLayout:
                                orientation: "horizontal"
                                adaptive_width: True
                                size_hint_y: None
                                height: "48dp"
                                spacing: "16dp"

                                MDButton:
                                    id: light_button
                                    style: "filled"
                                    size_hint: None, None
                                    size: "150dp", "48dp"
                                    on_release: root.set_light_theme()

                                    MDButtonText:
                                        text: "Light Mode"

                                MDButton:
                                    id: dark_button
                                    style: "filled"
                                    size_hint: None, None
                                    size: "150dp", "48dp"
                                    on_release: root.set_dark_theme()

                                    MDButtonText:
                                        text: "Dark Mode"

                                MDButton:
                                    id: pink_button
                                    style: "filled"
                                    size_hint: None, None
                                    size: "150dp", "48dp"
                                    on_release: root.set_pink_theme()

                                    MDButtonText:
                                        text: "Pookie Mode"

                                MDButton:
                                    id: cyber_button
                                    style: "filled"
                                    size_hint: None, None
                                    size: "150dp", "48dp"
                                    on_release: root.set_cyberpunk_theme()

                                    MDButtonText:
                                        text: "Cyberpunk"
                MDCard:
                    id: account_card
                    style: "filled"
                    md_bg_color: "#D5D0C6"
                    size_hint_y: None
                    height: "165dp"

                    MDBoxLayout:
                        orientation: "vertical"
                        padding: "18dp"
                        spacing: "15dp"

                        MDLabel:
                            text: "Account"
                            font_style: "Title"
                            theme_text_color: "Custom"
                            text_color: "#4A3426"

                        MDButton:
                            style: "filled"
                            on_release: root.update_account()

                            MDButtonText:
                                text: "Update Account"

                        MDButton:
                            style: "filled"
                            on_release: root.logout()

                            MDButtonText:
                                text: "Logout"

                MDCard:
                    id: notification_card
                    style: "filled"
                    md_bg_color: "#E7E1D4"
                    size_hint_y: None
                    height: "130dp"

                    MDBoxLayout:
                        orientation: "vertical"
                        padding: "18dp"
                        spacing: "15dp"

                        MDLabel:
                            text: "Notifications"
                            font_style: "Title"
                            theme_text_color: "Custom"
                            text_color: "#4A3426"

                        MDButton:
                            style: "filled"
                            on_release: root.toggle_notifications()

                            MDButtonText:
                                text: "Enable Notifications"

                MDCard:
                    id: about_card
                    style: "filled"
                    md_bg_color: "#D5D0C6"
                    size_hint_y: None
                    height: "110dp"

                    MDBoxLayout:
                        orientation: "vertical"
                        padding: "18dp"
                        spacing: "8dp"

                        MDLabel:
                            text: "About"
                            font_style: "Title"
                            theme_text_color: "Custom"
                            text_color: "#4A3426"

                        MDLabel:
                            text: "NoteNest v1.0"
                            adaptive_height: True
                            theme_text_color: "Custom"
                            text_color: "#4A3426"





