<SettingsScreen>:
    md_bg_color: "#EBD6A7"

    MDBoxLayout:
        orientation: "vertical"
        padding: "20dp"
        spacing: "18dp"

        MDBoxLayout:
            adaptive_height: True
            spacing: "12dp"
            padding: "0dp", "8dp"

            MDButton:
                style: "text"
                on_release: root.go_back()

                MDButtonIcon:
                    icon: "arrow-left"

            MDLabel:
                id: title_label
                text: "Settings"
                font_style: "Headline"
                theme_text_color: "Custom"
                text_color: "#4A3426"

        MDLabel:
            id: subtitle_label
            text: "Customize your NoteNest experience"
            adaptive_height: True
            font_style: "Body"
            theme_text_color: "Custom"
            text_color: "#8A5A2B"

        ScrollView:

            MDBoxLayout:
                orientation: "vertical"
                adaptive_height: True
                spacing: "22dp"
                padding: "4dp", "20dp", "4dp", "20dp"

                MDCard:
                    id: appearance_card
                    style: "filled"
                    md_bg_color: "#F7F1E6"
                    size_hint_y: None
                    height: "190dp"

                    MDBoxLayout:
                        orientation: "vertical"
                        padding: "18dp"
                        spacing: "10dp"

                        MDLabel:
                            text: "Theme"
                            font_style: "Title"
                            theme_text_color: "Custom"
                            text_color: "#4A3426"

                        MDLabel:
                            text: "Choose your preferred appearance"
                            adaptive_height: True
                            theme_text_color: "Custom"
                            text_color: "#8A5A2B"

                        ScrollView:
                            do_scroll_x: True
                            do_scroll_y: False
                            bar_width: "4dp"

                            MDBoxLayout:
                                orientation: "horizontal"
                                adaptive_width: True
                                size_hint_y: None
                                height: "48dp"
                                spacing: "16dp"

                                MDButton:
                                    id: light_button
                                    style: "filled"
                                    size_hint: None, None
                                    size: "150dp", "48dp"
                                    on_release: root.set_light_theme()

                                    MDButtonText:
                                        text: "Light Mode"

                                MDButton:
                                    id: dark_button
                                    style: "filled"
                                    size_hint: None, None
                                    size: "150dp", "48dp"
                                    on_release: root.set_dark_theme()

                                    MDButtonText:
                                        text: "Dark Mode"

                                MDButton:
                                    id: pink_button
                                    style: "filled"
                                    size_hint: None, None
                                    size: "150dp", "48dp"
                                    on_release: root.set_pink_theme()

                                    MDButtonText:
                                        text: "Pookie Mode"

                # ACCOUNT


                MDCard:
                    id: account_card
                    style: "filled"
                    md_bg_color: "#DCC089"
                    size_hint_y: None
                    height: "165dp"

                    MDBoxLayout:
                        orientation: "vertical"
                        padding: "18dp"
                        spacing: "15dp"

                        MDLabel:
                            text: "Account"
                            font_style: "Title"
                            theme_text_color: "Custom"
                            text_color: "#4A3426"

                        MDButton:
                            style: "filled"
                            on_release: root.update_account()

                            MDButtonText:
                                text: "Update Account"

                        MDButton:
                            style: "filled"
                            on_release: root.logout()

                            MDButtonText:
                                text: "Logout"

                # NOTIFICATIONS


                MDCard:
                    id: notification_card
                    style: "filled"
                    md_bg_color: "#EBD6A7"
                    size_hint_y: None
                    height: "130dp"

                    MDBoxLayout:
                        orientation: "vertical"
                        padding: "18dp"
                        spacing: "15dp"

                        MDLabel:
                            text: "Notifications"
                            font_style: "Title"
                            theme_text_color: "Custom"
                            text_color: "#4A3426"

                        MDButton:
                            style: "filled"
                            on_release: root.toggle_notifications()

                            MDButtonText:
                                text: "Enable Notifications"

                # ABOUT


                MDCard:
                    id: about_card
                    style: "filled"
                    md_bg_color: "#DCC089"
                    size_hint_y: None
                    height: "110dp"

                    MDBoxLayout:
                        orientation: "vertical"
                        padding: "18dp"
                        spacing: "8dp"

                        MDLabel:
                            text: "About"
                            font_style: "Title"
                            theme_text_color: "Custom"
                            text_color: "#4A3426"

                        MDLabel:
                            text: "NoteNest v1.0"
                            adaptive_height: True
                            theme_text_color: "Custom"
                            text_color: "#4A3426"
