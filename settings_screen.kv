<SettingsScreen>:
    MDBoxLayout:
        orientation: "vertical"
        padding: dp(16)
        spacing: dp(16)

        # top row: back arrow + title/subtitle
        MDBoxLayout:
            size_hint_y: None
            height: dp(56)
            spacing: dp(8)

            MDIconButton:
                id: back_button
                icon: "arrow-left"
                theme_icon_color: "Custom"
                on_release: root.go_back()

            MDBoxLayout:
                orientation: "vertical"

                MDLabel:
                    id: title_label
                    text: "Settings"
                    theme_text_color: "Custom"
                    font_style: "Title"
                    role: "medium"

                MDLabel:
                    id: subtitle_label
                    text: "Customize your NoteNest experience"
                    theme_text_color: "Custom"
                    font_style: "Body"
                    role: "small"

        ScrollView:
            MDBoxLayout:
                orientation: "vertical"
                spacing: dp(16)
                adaptive_height: True

                # ── theme card ──
                MDCard:
                    id: theme_card
                    orientation: "vertical"
                    padding: dp(16)
                    spacing: dp(12)
                    adaptive_height: True
                    radius: [16]

                    MDLabel:
                        id: theme_section_label
                        text: "Theme"
                        theme_text_color: "Custom"
                        font_style: "Body"
                        role: "medium"
                        adaptive_height: True

                    MDBoxLayout:
                        spacing: dp(8)
                        adaptive_height: True

                        MDButton:
                            id: light_button
                            style: "filled"
                            on_release: root.set_light_theme()
                            MDButtonText:
                                text: "Light"

                        MDButton:
                            id: dark_button
                            style: "filled"
                            on_release: root.set_dark_theme()
                            MDButtonText:
                                text: "Dark"

                        MDButton:
                            id: floral_button
                            style: "filled"
                            on_release: root.set_floral_theme()
                            MDButtonText:
                                text: "Floral"

                        MDButton:
                            id: cyber_button
                            style: "filled"
                            on_release: root.set_cyberpunk_theme()
                            MDButtonText:
                                text: "Cyberpunk"

                # ── account card: backup, sync, log out ──
                MDCard:
                    id: account_card
                    orientation: "vertical"
                    padding: dp(16)
                    spacing: dp(14)
                    adaptive_height: True
                    radius: [16]

                    MDLabel:
                        id: account_section_label
                        text: "Account"
                        theme_text_color: "Custom"
                        font_style: "Body"
                        role: "medium"
                        adaptive_height: True

                    # -- backup row --
                    MDBoxLayout:
                        size_hint_y: None
                        height: dp(40)
                        spacing: dp(8)

                        MDLabel:
                            id: backup_row_label
                            text: "Backup"
                            theme_text_color: "Custom"
                            font_style: "Title"
                            role: "small"

                        MDIconButton:
                            id: backup_chevron
                            icon: "chevron-right"
                            theme_icon_color: "Custom"
                            pos_hint: {"center_y": 0.5}
                            on_release: root.backup_data()

                    # -- sync row (label + subtitle + switch) --
                    MDBoxLayout:
                        size_hint_y: None
                        height: dp(56)
                        spacing: dp(8)

                        MDBoxLayout:
                            orientation: "vertical"
                            size_hint_x: 1

                            MDLabel:
                                id: sync_row_label
                                text: "Auto sync"
                                theme_text_color: "Custom"
                                font_style: "Title"
                                role: "small"
                                adaptive_height: True

                            MDLabel:
                                id: sync_row_subtitle
                                text: "Automatically sync notes when online"
                                theme_text_color: "Custom"
                                font_style: "Body"
                                role: "small"
                                adaptive_height: True

                        MDSwitch:
                            pos_hint: {"center_y": 0.5}
                            on_active: root.toggle_auto_sync()

                    # -- log out row --
                    MDBoxLayout:
                        size_hint_y: None
                        height: dp(40)
                        spacing: dp(8)

                        MDLabel:
                            id: logout_row_label
                            text: "Log out"
                            theme_text_color: "Custom"
                            font_style: "Title"
                            role: "small"

                        MDIconButton:
                            id: logout_chevron
                            icon: "chevron-right"
                            theme_icon_color: "Custom"
                            pos_hint: {"center_y": 0.5}
                            on_release: root.logout()

                # ── privacy card ──
                MDCard:
                    id: privacy_card
                    orientation: "vertical"
                    padding: dp(16)
                    spacing: dp(12)
                    adaptive_height: True
                    radius: [16]

                    MDLabel:
                        id: privacy_section_label
                        text: "Privacy"
                        theme_text_color: "Custom"
                        font_style: "Body"
                        role: "medium"
                        adaptive_height: True

                    MDBoxLayout:
                        size_hint_y: None
                        height: dp(56)
                        spacing: dp(8)

                        MDBoxLayout:
                            orientation: "vertical"
                            size_hint_x: 1

                            MDLabel:
                                id: privacy_row_label
                                text: "Privacy settings"
                                theme_text_color: "Custom"
                                font_style: "Title"
                                role: "small"
                                adaptive_height: True

                            MDLabel:
                                id: privacy_row_subtitle
                                text: "Manage app permissions and data"
                                theme_text_color: "Custom"
                                font_style: "Body"
                                role: "small"
                                adaptive_height: True

                        MDIconButton:
                            id: privacy_chevron
                            icon: "chevron-right"
                            theme_icon_color: "Custom"
                            pos_hint: {"center_y": 0.5}
                            on_release: root.open_privacy_settings()

                # ── notifications card ──
                MDCard:
                    id: notifications_card
                    orientation: "vertical"
                    padding: dp(16)
                    spacing: dp(12)
                    adaptive_height: True
                    radius: [16]

                    MDLabel:
                        id: notifications_section_label
                        text: "Notifications"
                        theme_text_color: "Custom"
                        font_style: "Body"
                        role: "medium"
                        adaptive_height: True

                    MDBoxLayout:
                        size_hint_y: None
                        height: dp(40)
                        spacing: dp(8)

                        MDLabel:
                            id: notifications_row_label
                            text: "Enable notifications"
                            theme_text_color: "Custom"
                            font_style: "Title"
                            role: "small"

                        MDSwitch:
                            pos_hint: {"center_y": 0.5}
                            on_active: root.toggle_notifications()

                # ── trash card ──
                MDCard:
                    id: trash_card
                    orientation: "vertical"
                    padding: dp(16)
                    spacing: dp(12)
                    adaptive_height: True
                    radius: [16]

                    MDLabel:
                        id: trash_section_label
                        text: "Trash"
                        theme_text_color: "Custom"
                        font_style: "Body"
                        role: "medium"
                        adaptive_height: True

                    MDBoxLayout:
                        size_hint_y: None
                        height: dp(56)
                        spacing: dp(8)

                        MDBoxLayout:
                            orientation: "vertical"
                            size_hint_x: 1

                            MDLabel:
                                id: trash_row_label
                                text: "Trash"
                                theme_text_color: "Custom"
                                font_style: "Title"
                                role: "small"
                                adaptive_height: True

                            MDLabel:
                                id: trash_row_subtitle
                                text: "Deleted notes are kept here"
                                theme_text_color: "Custom"
                                font_style: "Body"
                                role: "small"
                                adaptive_height: True

                        MDIconButton:
                            id: trash_chevron
                            icon: "chevron-right"
                            theme_icon_color: "Custom"
                            pos_hint: {"center_y": 0.5}
                            on_release: root.open_trash()

                # ── about card ──
                MDCard:
                    id: about_card
                    orientation: "vertical"
                    padding: dp(16)
                    spacing: dp(12)
                    adaptive_height: True
                    radius: [16]

                    MDLabel:
                        id: about_section_label
                        text: "About NoteNest"
                        theme_text_color: "Custom"
                        font_style: "Body"
                        role: "medium"
                        adaptive_height: True

                    MDBoxLayout:
                        size_hint_y: None
                        height: dp(40)
                        spacing: dp(8)

                        MDLabel:
                            id: rate_row_label
                            text: "Rate app"
                            theme_text_color: "Custom"
                            font_style: "Title"
                            role: "small"

                        MDIconButton:
                            id: rate_chevron
                            icon: "chevron-right"
                            theme_icon_color: "Custom"
                            pos_hint: {"center_y": 0.5}
                            on_release: root.rate_app()

                    MDBoxLayout:
                        size_hint_y: None
                        height: dp(40)
                        spacing: dp(8)

                        MDLabel:
                            id: privacy_policy_row_label
                            text: "Privacy policy"
                            theme_text_color: "Custom"
                            font_style: "Title"
                            role: "small"

                        MDIconButton:
                            id: privacy_policy_chevron
                            icon: "chevron-right"
                            theme_icon_color: "Custom"
                            pos_hint: {"center_y": 0.5}
                            on_release: root.open_privacy_policy()

                    MDLabel:
                        id: footer_label
                        text: "CSE299(10) Group 3, Summer 2026"
                        theme_text_color: "Custom"
                        font_style: "Body"
                        role: "small"
                        adaptive_height: True