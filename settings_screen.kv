
<SettingsScreen>:
    MDBoxLayout:
        orientation: "vertical"
        padding: dp(16)
        spacing: dp(16)

        # top row: back arrow + title/subtitle
        MDBoxLayout:
            size_hint_y: None
            height: dp(56)
            spacing: dp(8)

            MDIconButton:
                icon: "arrow-left"
                on_release: root.go_back()

            MDBoxLayout:
                orientation: "vertical"

                MDLabel:
                    id: title_label
                    text: "Settings"
                    font_style: "Title"
                    role: "medium"

                MDLabel:
                    id: subtitle_label
                    text: "Customize your NoteNest experience"
                    font_style: "Body"
                    role: "small"

        ScrollView:
            MDBoxLayout:
                orientation: "vertical"
                spacing: dp(16)
                adaptive_height: True

                # ── appearance card: theme buttons ──
                MDCard:
                    id: appearance_card
                    orientation: "vertical"
                    padding: dp(16)
                    spacing: dp(12)
                    adaptive_height: True
                    radius: [16]

                    MDLabel:
                        text: "Appearance"

                    MDBoxLayout:
                        spacing: dp(8)
                        adaptive_height: True

                        MDButton:
                            id: light_button
                            style: "filled"
                            on_release: root.set_light_theme()
                            MDButtonText:
                                text: "Light"

                        MDButton:
                            id: dark_button
                            style: "filled"
                            on_release: root.set_dark_theme()
                            MDButtonText:
                                text: "Dark"

                        MDButton:
                            id: floral_button
                            style: "filled"
                            on_release: root.set_pink_theme()
                            MDButtonText:
                                text: "Floral"

                        MDButton:
                            id: cyber_button
                            style: "filled"
                            on_release: root.set_cyberpunk_theme()
                            MDButtonText:
                                text: "Cyberpunk"

                # ── account card ──
                MDCard:
                    id: account_card
                    orientation: "vertical"
                    padding: dp(16)
                    spacing: dp(12)
                    adaptive_height: True
                    radius: [16]

                    MDLabel:
                        text: "Account"

                    MDButton:
                        style: "filled"
                        on_release: root.update_account()
                        MDButtonText:
                            text: "Update account"

                    MDButton:
                        style: "filled"
                        on_release: root.logout()
                        MDButtonText:
                            text: "Log out"

                # ── notifications card ──
                MDCard:
                    id: notification_card
                    orientation: "vertical"
                    padding: dp(16)
                    spacing: dp(12)
                    adaptive_height: True
                    radius: [16]

                    MDLabel:
                        text: "Notifications"

                    MDSwitch:
                        on_active: root.toggle_notifications()

                # ── about card ──
                MDCard:
                    id: about_card
                    orientation: "vertical"
                    padding: dp(16)
                    spacing: dp(12)
                    adaptive_height: True
                    radius: [16]

                    MDLabel:
                        text: "About NoteNest"

                    MDLabel:
                        text: "CSE299(10) Group 3, Summer 2026"