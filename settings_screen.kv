<SettingsScreen>:
    MDBoxLayout:
        orientation: "vertical"
        padding: dp(16)
        spacing: dp(16)

        # top row: back arrow + title/subtitle
        MDBoxLayout:
            size_hint_y: None
            height: dp(56)
            spacing: dp(8)

            MDIconButton:
                id: back_button
                icon: "arrow-left"
                theme_icon_color: "Custom"
                on_release: root.go_back()

            MDBoxLayout:
                orientation: "vertical"

                MDLabel:
                    id: title_label
                    text: "Settings"
                    theme_text_color: "Custom"
                    font_style: "Title"
                    role: "medium"

                MDLabel:
                    id: subtitle_label
                    text: "Customize your NoteNest experience"
                    theme_text_color: "Custom"
                    font_style: "Body"
                    role: "small"

        ScrollView:
            MDBoxLayout:
                orientation: "vertical"
                spacing: dp(16)
                adaptive_height: True

                # ── theme card ──
                MDCard:
                    id: theme_card
                    orientation: "vertical"
                    padding: dp(16)
                    spacing: dp(12)
                    adaptive_height: True
                    radius: [16]

                    MDLabel:
                        id: theme_section_label
                        text: "Theme"
                        theme_text_color: "Custom"
                        font_style: "Body"
                        role: "medium"
                        adaptive_height: True

                    ScrollView:
                        size_hint_y: None
                        height: dp(48)
                        do_scroll_x: True
                        do_scroll_y: False
                        bar_width: dp(0)

                        MDBoxLayout:
                            # size_hint_x: None + width: self.minimum_width
                            # is what lets this row be WIDER than the
                            # ScrollView's visible area -- without this,
                            # the row would just shrink to fit and there
                            # would be nothing to scroll.
                            size_hint_x: None
                            width: self.minimum_width
                            spacing: dp(8)
                            padding: dp(2), 0

                            MDButton:
                                id: default_button
                                style: "filled"
                                on_release: root.set_default_theme()
                                MDButtonText:
                                    text: "Default"

                            MDButton:
                                id: dark_button
                                style: "filled"
                                on_release: root.set_dark_theme()
                                MDButtonText:
                                    text: "Dark"

                            MDButton:
                                id: cream_button
                                style: "filled"
                                on_release: root.set_cream_theme()
                                MDButtonText:
                                    text: "Cream"

                            MDButton:
                                id: matcha_button
                                style: "filled"
                                on_release: root.set_matcha_theme()
                                MDButtonText:
                                    text: "Matcha"

                            MDButton:
                                id: monochrome_button
                                style: "filled"
                                on_release: root.set_monochrome_theme()
                                MDButtonText:
                                    text: "Monochrome"

                # ── google account card: identity only ──
                MDCard:
                    id: account_card
                    orientation: "vertical"
                    padding: dp(16)
                    spacing: dp(14)
                    adaptive_height: True
                    radius: [16]

                    MDLabel:
                        id: account_section_label
                        text: "Google Account"
                        theme_text_color: "Custom"
                        font_style: "Body"
                        role: "medium"
                        adaptive_height: True

                    # -- connect google row (label + subtitle + chevron) --
                    MDBoxLayout:
                        size_hint_y: None
                        height: dp(56)
                        spacing: dp(8)

                        MDBoxLayout:
                            orientation: "vertical"
                            size_hint_x: 1

                            MDLabel:
                                id: connect_google_row_label
                                text: "Connect Google account"
                                theme_text_color: "Custom"
                                font_style: "Title"
                                role: "small"
                                adaptive_height: True

                            MDLabel:
                                id: connect_google_row_subtitle
                                text: "Sign in to enable cloud backup"
                                theme_text_color: "Custom"
                                font_style: "Body"
                                role: "small"
                                adaptive_height: True

                        MDIconButton:
                            id: connect_google_chevron
                            icon: "chevron-right"
                            theme_icon_color: "Custom"
                            pos_hint: {"center_y": 0.5}
                            on_release: root.connect_google_account()

                    # -- log out row --
                    MDBoxLayout:
                        size_hint_y: None
                        height: dp(40)
                        spacing: dp(8)

                        MDLabel:
                            id: logout_row_label
                            text: "Log out"
                            theme_text_color: "Custom"
                            font_style: "Title"
                            role: "small"

                        MDIconButton:
                            id: logout_chevron
                            icon: "chevron-right"
                            theme_icon_color: "Custom"
                            pos_hint: {"center_y": 0.5}
                            on_release: root.logout()

                # ── backup & restore card: data actions ──
                MDCard:
                    id: backup_card
                    orientation: "vertical"
                    padding: dp(16)
                    spacing: dp(14)
                    adaptive_height: True
                    radius: [16]

                    MDLabel:
                        id: backup_section_label
                        text: "Backup & Restore"
                        theme_text_color: "Custom"
                        font_style: "Body"
                        role: "medium"
                        adaptive_height: True

                    # -- back up now row --
                    MDBoxLayout:
                        size_hint_y: None
                        height: dp(40)
                        spacing: dp(8)

                        MDLabel:
                            id: backup_now_row_label
                            text: "Back up now"
                            theme_text_color: "Custom"
                            font_style: "Title"
                            role: "small"

                        MDIconButton:
                            id: backup_now_chevron
                            icon: "chevron-right"
                            theme_icon_color: "Custom"
                            pos_hint: {"center_y": 0.5}
                            on_release: root.backup_now()

                    # -- restore row (label + subtitle + chevron) --
                    MDBoxLayout:
                        size_hint_y: None
                        height: dp(56)
                        spacing: dp(8)

                        MDBoxLayout:
                            orientation: "vertical"
                            size_hint_x: 1

                            MDLabel:
                                id: restore_row_label
                                text: "Restore backup"
                                theme_text_color: "Custom"
                                font_style: "Title"
                                role: "small"
                                adaptive_height: True

                            MDLabel:
                                id: restore_row_subtitle
                                text: "Replace local data with your latest backup"
                                theme_text_color: "Custom"
                                font_style: "Body"
                                role: "small"
                                adaptive_height: True

                        MDIconButton:
                            id: restore_chevron
                            icon: "chevron-right"
                            theme_icon_color: "Custom"
                            pos_hint: {"center_y": 0.5}
                            on_release: root.restore_backup()

                    # -- auto backup row (label + subtitle + switch) --
                    MDBoxLayout:
                        size_hint_y: None
                        height: dp(56)
                        spacing: dp(8)

                        MDBoxLayout:
                            orientation: "vertical"
                            size_hint_x: 1

                            MDLabel:
                                id: auto_backup_row_label
                                text: "Auto backup"
                                theme_text_color: "Custom"
                                font_style: "Title"
                                role: "small"
                                adaptive_height: True

                            MDLabel:
                                id: auto_backup_row_subtitle
                                text: "Automatically back up when online"
                                theme_text_color: "Custom"
                                font_style: "Body"
                                role: "small"
                                adaptive_height: True

                        MDSwitch:
                            pos_hint: {"center_y": 0.5}
                            on_active: root.toggle_auto_backup()

                    # -- export row --
                    MDBoxLayout:
                        size_hint_y: None
                        height: dp(40)
                        spacing: dp(8)

                        MDLabel:
                            id: export_row_label
                            text: "Export to file"
                            theme_text_color: "Custom"
                            font_style: "Title"
                            role: "small"

                        MDIconButton:
                            id: export_chevron
                            icon: "chevron-right"
                            theme_icon_color: "Custom"
                            pos_hint: {"center_y": 0.5}
                            on_release: root.export_to_file()

                    # -- import row --
                    MDBoxLayout:
                        size_hint_y: None
                        height: dp(40)
                        spacing: dp(8)

                        MDLabel:
                            id: import_row_label
                            text: "Import from file"
                            theme_text_color: "Custom"
                            font_style: "Title"
                            role: "small"

                        MDIconButton:
                            id: import_chevron
                            icon: "chevron-right"
                            theme_icon_color: "Custom"
                            pos_hint: {"center_y": 0.5}
                            on_release: root.import_from_file()

                # ── privacy card ──
                MDCard:
                    id: privacy_card
                    orientation: "vertical"
                    padding: dp(16)
                    spacing: dp(12)
                    adaptive_height: True
                    radius: [16]

                    MDLabel:
                        id: privacy_section_label
                        text: "Privacy"
                        theme_text_color: "Custom"
                        font_style: "Body"
                        role: "medium"
                        adaptive_height: True

                    MDBoxLayout:
                        size_hint_y: None
                        height: dp(56)
                        spacing: dp(8)

                        MDBoxLayout:
                            orientation: "vertical"
                            size_hint_x: 1

                            MDLabel:
                                id: privacy_row_label
                                text: "Privacy settings"
                                theme_text_color: "Custom"
                                font_style: "Title"
                                role: "small"
                                adaptive_height: True

                            MDLabel:
                                id: privacy_row_subtitle
                                text: "Manage app permissions and data"
                                theme_text_color: "Custom"
                                font_style: "Body"
                                role: "small"
                                adaptive_height: True

                        MDIconButton:
                            id: privacy_chevron
                            icon: "chevron-right"
                            theme_icon_color: "Custom"
                            pos_hint: {"center_y": 0.5}
                            on_release: root.open_privacy_settings()

                # ── notifications card ──
                MDCard:
                    id: notifications_card
                    orientation: "vertical"
                    padding: dp(16)
                    spacing: dp(12)
                    adaptive_height: True
                    radius: [16]

                    MDLabel:
                        id: notifications_section_label
                        text: "Notifications"
                        theme_text_color: "Custom"
                        font_style: "Body"
                        role: "medium"
                        adaptive_height: True

                    MDBoxLayout:
                        size_hint_y: None
                        height: dp(40)
                        spacing: dp(8)

                        MDLabel:
                            id: notifications_row_label
                            text: "Enable notifications"
                            theme_text_color: "Custom"
                            font_style: "Title"
                            role: "small"

                        MDSwitch:
                            pos_hint: {"center_y": 0.5}
                            on_active: root.toggle_notifications()

                # ── about card ──
                MDCard:
                    id: about_card
                    orientation: "vertical"
                    padding: dp(16)
                    spacing: dp(12)
                    adaptive_height: True
                    radius: [16]

                    MDLabel:
                        id: about_section_label
                        text: "About NoteNest"
                        theme_text_color: "Custom"
                        font_style: "Body"
                        role: "medium"
                        adaptive_height: True

                    MDBoxLayout:
                        size_hint_y: None
                        height: dp(40)
                        spacing: dp(8)

                        MDLabel:
                            id: rate_row_label
                            text: "Rate app"
                            theme_text_color: "Custom"
                            font_style: "Title"
                            role: "small"

                        MDIconButton:
                            id: rate_chevron
                            icon: "chevron-right"
                            theme_icon_color: "Custom"
                            pos_hint: {"center_y": 0.5}
                            on_release: root.rate_app()

                    MDBoxLayout:
                        size_hint_y: None
                        height: dp(40)
                        spacing: dp(8)

                        MDLabel:
                            id: privacy_policy_row_label
                            text: "Privacy policy"
                            theme_text_color: "Custom"
                            font_style: "Title"
                            role: "small"

                        MDIconButton:
                            id: privacy_policy_chevron
                            icon: "chevron-right"
                            theme_icon_color: "Custom"
                            pos_hint: {"center_y": 0.5}
                            on_release: root.open_privacy_policy()

                    MDLabel:
                        id: footer_label
                        text: "CSE299(10) Group 3, Summer 2026"
                        theme_text_color: "Custom"
                        font_style: "Body"
                        role: "small"
                        adaptive_height: True